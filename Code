        cx, cy, r = 15, 15, 13
        pts = []
        for i in range(6):
            a = math.pi / 6 + i * math.pi / 3
            pts.append(cx + r * math.cos(a))
            pts.append(cy + r * math.sin(a))
        # glow rings
        for i in range(3):
            gr = r + 3 + i * 2
            gpts = []
            for j in range(6):
                a = math.pi / 6 + j * math.pi / 3
                gpts.append(cx + gr * math.cos(a))
                gpts.append(cy + gr * math.sin(a))
        c.create_polygon(pts, fill=TH['pri'], outline=TH['pri_hov'], width=1)
        c.create_text(cx, cy + 1, text='Q', fill='#fff',
                      font=('Segoe UI', 10, 'bold'))

