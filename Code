# ─── Auto-install missing dependencies ─────────────────────────────────────
def _pip(*args):
    """Run a pip command silently, return True on success."""
    try:
        subprocess.check_call(
            [sys.executable, '-m', 'pip'] + list(args),
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return True
    except Exception:
        return False

def _has_wrong_websocket():
    """Detect the wrong 'websocket' package without importing it."""
    try:
        out = subprocess.check_output(
            [sys.executable, '-m', 'pip', 'show', 'websocket'],
            stderr=subprocess.DEVNULL,
        ).decode()
        # pip show "websocket" means the WRONG package is installed
        if 'Name: websocket' in out:
            return True
    except Exception:
        pass
    return False

def install_dependencies():
    """Auto-install missing dependencies with a GUI window showing progress."""
    # ── Step 1: If the wrong 'websocket' package exists, remove it first ──
    if _has_wrong_websocket():
        _pip('uninstall', 'websocket', '-y', '-q')

    # ── Step 2: Check what's actually missing (using subprocess, NOT import) ──
    missing = []
    for pkg in ('requests', 'websocket-client', 'psutil'):
        if _pip('show', pkg):
            continue
        # For websocket-client, also check if the module importable
        if pkg == 'websocket-client':
            try:
                import importlib
                mod = importlib.import_module('websocket')
                if hasattr(mod, 'create_connection'):
                    continue          # correct package already usable
            except ImportError:
                pass
        missing.append(pkg)

    if not missing:
        return

    # ── Step 3: Show progress window and install ───────────────────────────
    progress_root = tk.Tk()
    progress_root.title("Installing Dependencies")
    progress_root.geometry("400x150")
    progress_root.configure(bg='#0a0a16')
    progress_root.resizable(False, False)

    progress_root.update_idletasks()
    w = progress_root.winfo_width()
    h = progress_root.winfo_height()
    x = (progress_root.winfo_screenwidth() // 2) - (w // 2)
    y = (progress_root.winfo_screenheight() // 2) - (h // 2)
    progress_root.geometry(f'{w}x{h}+{x}+{y}')

    tk.Label(progress_root, text="Installing Dependencies",
             fg='#e4e8ff', bg='#0a0a16',
             font=('Segoe UI', 12, 'bold')).pack(pady=(20, 10))

    status = tk.Label(progress_root, text="Please wait...",
                      fg='#a0a4c8', bg='#0a0a16',
                      font=('Segoe UI', 10))
    status.pack(pady=5)

    bar = tk.Canvas(progress_root, height=6, bg='#13132a', highlightthickness=0)
    bar.pack(fill=tk.X, padx=40, pady=10)
    inner = tk.Canvas(bar, height=6, bg='#7c6aff', highlightthickness=0)
    inner.place(x=0, y=0, width=0, height=6)
    progress_root.update()

    for i, pkg in enumerate(missing):
        status.config(text=f"Installing {pkg}...")
        progress_root.update()
        ok = _pip('install', pkg, '--quiet', '--no-cache-dir')
        if not ok:
            _pip('install', pkg, '--quiet', '--user', '--no-cache-dir')
        bw = bar.winfo_width()
        inner.config(width=int(bw * (i + 1) / len(missing)))
        progress_root.update()

    # ── Step 4: Nuke the cached wrong module so fresh import works ─────────
    for key in list(sys.modules):
        if key == 'websocket' or key.startswith('websocket.'):
            del sys.modules[key]

    status.config(text="Dependencies installed successfully!", fg='#00d68f')
    progress_root.update()
    time.sleep(0.5)
    progress_root.destroy()

# ─── Install dependencies before starting ──────────────────────────────────
install_dependencies()

