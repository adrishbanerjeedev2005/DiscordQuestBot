    # ── Discord management ──────────────────────────────────────────────
    def _check_discord(self):
        found = any('discord' in (p.info.get('name') or '').lower()
                    for p in psutil.process_iter(['name']))
        self._set_status('discord running' if found else 'idle',
                         'running' if found else 'idle')
        self.root.after(5000, self._check_discord)

    def _kill_discord(self):
        for proc in psutil.process_iter(['pid', 'name']):
            try:
                if 'discord' in (proc.info.get('name') or '').lower():
                    proc.kill()
            except Exception:
                pass

    def _launch_discord(self):
        self._kill_discord()
        time.sleep(2)
        system = platform.system()
        if system == 'Windows':
            base = os.path.expandvars(r'%LOCALAPPDATA%\Discord')
            exes = []
            if os.path.exists(base):
                for item in os.listdir(base):
                    if item.startswith('app-'):
                        p = os.path.join(base, item, 'Discord.exe')
                        if os.path.exists(p):
                            exes.append(p)
            exes.sort(reverse=True)
            path = exes[0] if exes else os.path.expandvars(r'%LOCALAPPDATA%\Discord\Discord.exe')
        elif system == 'Darwin':
            path = '/Applications/Discord.app/Contents/MacOS/Discord'
        else:
            path = 'discord'
        self._log('Launching Discord with debug port…', 'info')
        self.discord_process = subprocess.Popen([
            path,
            f'--remote-debugging-port={self.debug_port}',
            '--remote-allow-origins=*',
        ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        self._log('Waiting for Discord to load…', 'info')
        time.sleep(15)
        return True

    def _get_ws_url(self):
        for _ in range(30):
            try:
                res = requests.get(f'http://localhost:{self.debug_port}/json')
                for page in res.json():
                    if 'discord.com' in page.get('url', ''):
                        return page['webSocketDebuggerUrl']
                data = res.json()
                if data:
                    return data[0]['webSocketDebuggerUrl']
            except Exception:
                pass
            time.sleep(2)
        return None

    # ── WebSocket injection ──────────────────────────────────────────────
    def _monitor_ws(self):
        try:
            while self.running:
                try:
                    data = json.loads(self.ws.recv())
                    if data.get('method') == 'Runtime.consoleAPICalled':
                        for arg in data['params'].get('args', []):
                            val = arg.get('value', '')
                            if isinstance(val, str) and val.startswith('GUI:'):
                                parts = val.split(':', 2)
                                if len(parts) == 3:
                                    self.root.after(0, self._handle, parts[1], parts[2])
                except Exception:
                    break
        except Exception:
            pass

    def _handle(self, t, v):
        if t == 'total':
            self.st_total.update(v)
        elif t == 'completed':
            self.st_done.update(v)
        elif t == 'progress':
            try:
                pct = int(v)
                self.st_pct.update(f'{pct}%')
                self.pbar.set(pct)
                self.pct_lbl.config(text=f'{pct}%')
            except ValueError:
                pass
        elif t == 'spoof':
            # Truncate the game name to fit in the tile
            if len(v) > 14:
                short = v[:12] + '…'
            else:
                short = v
            self.st_spoof.update(short)
            self._log(f'spoofing  {v}', 'info')
        elif t == 'quest':
            self.quest_lbl.config(text=v)
            self._log(f'starting  {v}', 'quest')
        elif t == 'success':
            self._log(f'✓  {v}', 'success')
        elif t == 'error':
            self._log(f'✗  {v}', 'error')
        elif t == 'warning':
            self._log(f'⚠  {v}', 'warning')

    def _inject(self):
        ws_url = self._get_ws_url()
        if not ws_url:
            self._log('Could not find Discord debug endpoint.', 'error')
            return False
        try:
            # Re-import websocket to make sure we have the right module
            import websocket as ws_module
            self.ws = ws_module.create_connection(
                ws_url, origin='http://localhost',
                header={'Origin': 'http://localhost'})
            self.ws.send(json.dumps({'id': 1, 'method': 'Runtime.enable'}))
            self.ws.recv()
            self.monitor_thread = threading.Thread(target=self._monitor_ws, daemon=True)
            self.monitor_thread.start()
            self.ws.send(json.dumps({'id': 2, 'method': 'Runtime.evaluate',
                                     'params': {'expression': self.quest_script,
                                                'returnByValue': False}}))
            self.ws.recv()
            self._log('Script injected successfully.', 'success')
            return True
        except Exception as e:
            self._log(f'Injection failed: {e}', 'error')
            return False

    # ── Lifecycle ────────────────────────────────────────────────────────
    def _start(self):
        if self.running:
            return
        self.running = True
        self.btn_start.config_state(tk.DISABLED)
        self.btn_stop.config_state(tk.NORMAL)
        self._set_status('running', 'running')
        self._clear_log()
        self._log('Automation started.', 'info')
        self.st_total.update('…')
        self.st_done.update('0')
        self.st_pct.update('0%')
        self.st_spoof.update('—')
        self.quest_lbl.config(text='Initialising…')
        self.pbar.set(0)
        self.pct_lbl.config(text='0%')
        self.footer_lbl.config(text='Running — do not close Discord', fg=TH['green'])
        threading.Thread(target=self._run, daemon=True).start()

    def _run(self):
        try:
            if not self._launch_discord():
                self._log('Failed to launch Discord.', 'error')
                self.root.after(0, self._stop)
                return
            if not self._inject():
                self._log('Script injection failed.', 'error')
                self.root.after(0, self._stop)
                return
            self._log('Running — press STOP when done.', 'info')
            while self.running:
                time.sleep(0.1)
        except Exception as e:
            self._log(f'Error: {e}', 'error')
            self.root.after(0, self._stop)

    def _stop(self):
        self.running = False
        self.btn_start.config_state(tk.NORMAL)
        self.btn_stop.config_state(tk.DISABLED)
        self._set_status('stopped', 'stopped')
        if self.ws:
            try:
                self.ws.close()
            except Exception:
                pass
            self.ws = None
        self._log('Stopped.', 'warning')
        self.footer_lbl.config(text='Stopped', fg=TH['yellow'])

    def _cleanup(self):
        self.running = False
        if self.ws:
            try:
                self.ws.close()
            except Exception:
                pass
        if self.discord_process:
            try:
                self.discord_process.terminate()
            except Exception:
                pass

    def _on_close(self):
        self._cleanup()
        self.root.destroy()
        sys.exit(0)

    # ── Quest JS ─────────────────────────────────────────────────────────
    def _quest_js(self):
        return r"""
delete window.$;
let wpRequire = webpackChunkdiscord_app.push([[Symbol()], {}, r => r]);
webpackChunkdiscord_app.pop();

let ApplicationStreamingStore = Object.values(wpRequire.c).find(x => x?.exports?.A?.__proto__?.getStreamerActiveStreamMetadata).exports.A;
let RunningGameStore = Object.values(wpRequire.c).find(x => x?.exports?.Ay?.getRunningGames).exports.Ay;
let QuestsStore = Object.values(wpRequire.c).find(x => x?.exports?.A?.__proto__?.getQuest).exports.A;
let ChannelStore = Object.values(wpRequire.c).find(x => x?.exports?.A?.__proto__?.getAllThreadsForParent).exports.A;
let GuildChannelStore = Object.values(wpRequire.c).find(x => x?.exports?.Ay?.getSFWDefaultChannel).exports.Ay;
let FluxDispatcher = Object.values(wpRequire.c).find(x => x?.exports?.h?.__proto__?.flushWaitQueue).exports.h;
let api = Object.values(wpRequire.c).find(x => x?.exports?.Bo?.get).exports.Bo;

const supportedTasks = ["WATCH_VIDEO", "PLAY_ON_DESKTOP", "STREAM_ON_DESKTOP", "PLAY_ACTIVITY", "WATCH_VIDEO_ON_MOBILE"]
let quests = [...QuestsStore.quests.values()].filter(x => x.userStatus?.enrolledAt && !x.userStatus?.completedAt && new Date(x.config.expiresAt).getTime() > Date.now() && supportedTasks.find(y => Object.keys((x.config.taskConfig ?? x.config.taskConfigV2).tasks).includes(y)))
let isApp = typeof DiscordNative !== "undefined"

function sendStatus(msg, type) { console.log(`GUI:${type}:${msg}`); }

let totalQuests = quests.length;
let completedQuests = 0;
sendStatus(`${totalQuests}`, 'total');
sendStatus('0', 'completed');

if(quests.length === 0) {
    sendStatus('No quests found!', 'error');
} else {
    let doJob = function() {
        const quest = quests.pop()
        if(!quest) { sendStatus('All quests completed!', 'success'); return; }

        const pid = Math.floor(Math.random() * 30000) + 1000
        const applicationId = quest.config.application.id
        const applicationName = quest.config.application.name
        const questName = quest.config.messages.questName
        const taskConfig = quest.config.taskConfig ?? quest.config.taskConfigV2
        const taskName = supportedTasks.find(x => taskConfig.tasks[x] != null)
        const secondsNeeded = taskConfig.tasks[taskName].target
        let secondsDone = quest.userStatus?.progress?.[taskName]?.value ?? 0
        const progressPercent = Math.round((secondsDone / secondsNeeded) * 100);

        sendStatus(`${questName}`, 'quest');
        sendStatus(`${applicationName}`, 'spoof');
        sendStatus(`${progressPercent}`, 'progress');

        if(taskName === "WATCH_VIDEO" || taskName === "WATCH_VIDEO_ON_MOBILE") {
            const maxFuture = 10, speed = 7, interval = 1
            const enrolledAt = new Date(quest.userStatus.enrolledAt).getTime()
            let completed = false
            let fn = async () => {
                while(true) {
                    const maxAllowed = Math.floor((Date.now() - enrolledAt)/1000) + maxFuture
                    const diff = maxAllowed - secondsDone
                    const timestamp = secondsDone + speed
                    if(diff >= speed) {
                        const res = await api.post({url: `/quests/${quest.id}/video-progress`, body: {timestamp: Math.min(secondsNeeded, timestamp + Math.random())}})
                        completed = res.body.completed_at != null
                        secondsDone = Math.min(secondsNeeded, timestamp)
                        sendStatus(`${Math.round((secondsDone / secondsNeeded) * 100)}`, 'progress');
                    }
                    if(timestamp >= secondsNeeded) break
                    await new Promise(resolve => setTimeout(resolve, interval * 1000))
                }
                if(!completed) await api.post({url: `/quests/${quest.id}/video-progress`, body: {timestamp: secondsNeeded}})
                completedQuests++;
                sendStatus(`${completedQuests}`, 'completed');
                sendStatus(`${questName}`, 'success');
                doJob()
            }
            fn()
        } else if(taskName === "PLAY_ON_DESKTOP") {
            if(!isApp) { sendStatus('Desktop app required!', 'error'); doJob(); return; }
            api.get({url: `/applications/public?application_ids=${applicationId}`}).then(res => {
                const appData = res.body[0]
                const exeName = appData.executables?.find(x => x.os === "win32")?.name?.replace(">","") ?? appData.name.replace(/[\\/:*?"<>|]/g, "")
                const fakeGame = {
                    cmdLine: `C:\\Program Files\\${appData.name}\\${exeName}`,
                    exeName, exePath: `c:/program files/${appData.name.toLowerCase()}/${exeName}`,
                    hidden: false, isLauncher: false, id: applicationId, name: appData.name,
                    pid, pidPath: [pid], processName: appData.name, start: Date.now(),
                }
                const realGames = RunningGameStore.getRunningGames()
                const fakeGames = [fakeGame]
                const realGetRunningGames = RunningGameStore.getRunningGames
                const realGetGameForPID = RunningGameStore.getGameForPID
                RunningGameStore.getRunningGames = () => fakeGames
                RunningGameStore.getGameForPID = (pid) => fakeGames.find(x => x.pid === pid)
                FluxDispatcher.dispatch({type: "RUNNING_GAMES_CHANGE", removed: realGames, added: [fakeGame], games: fakeGames})
                let lastProgress = -1;
                let fn = data => {
                    let progress = quest.config.configVersion === 1 ? data.userStatus.streamProgressSeconds : Math.floor(data.userStatus.progress.PLAY_ON_DESKTOP.value)
                    if(progress !== lastProgress) {
                        sendStatus(`${Math.round((progress / secondsNeeded) * 100)}`, 'progress');
                        lastProgress = progress;
                    }
                    if(progress >= secondsNeeded) {
                        RunningGameStore.getRunningGames = realGetRunningGames
                        RunningGameStore.getGameForPID = realGetGameForPID
                        FluxDispatcher.dispatch({type: "RUNNING_GAMES_CHANGE", removed: [fakeGame], added: [], games: []})
                        FluxDispatcher.unsubscribe("QUESTS_SEND_HEARTBEAT_SUCCESS", fn)
                        completedQuests++;
                        sendStatus(`${completedQuests}`, 'completed');
                        sendStatus(`${questName}`, 'success');
                        doJob()
                    }
                }
                FluxDispatcher.subscribe("QUESTS_SEND_HEARTBEAT_SUCCESS", fn)
            })
        } else if(taskName === "STREAM_ON_DESKTOP") {
            if(!isApp) { sendStatus('Desktop app required!', 'error'); doJob(); return; }
            let realFunc = ApplicationStreamingStore.getStreamerActiveStreamMetadata
            ApplicationStreamingStore.getStreamerActiveStreamMetadata = () => ({id: applicationId, pid, sourceName: null})
            let lastProgress = -1;
            let fn = data => {
                let progress = quest.config.configVersion === 1 ? data.userStatus.streamProgressSeconds : Math.floor(data.userStatus.progress.STREAM_ON_DESKTOP.value)
                if(progress !== lastProgress) {
                    sendStatus(`${Math.round((progress / secondsNeeded) * 100)}`, 'progress');
                    lastProgress = progress;
                }
                if(progress >= secondsNeeded) {
                    ApplicationStreamingStore.getStreamerActiveStreamMetadata = realFunc
                    FluxDispatcher.unsubscribe("QUESTS_SEND_HEARTBEAT_SUCCESS", fn)
                    completedQuests++;
                    sendStatus(`${completedQuests}`, 'completed');
                    sendStatus(`${questName}`, 'success');
                    doJob()
                }
            }
            FluxDispatcher.subscribe("QUESTS_SEND_HEARTBEAT_SUCCESS", fn)
            sendStatus('Need 1+ person in VC to stream', 'warning');
        } else if(taskName === "PLAY_ACTIVITY") {
            const channelId = ChannelStore.getSortedPrivateChannels()[0]?.id ?? Object.values(GuildChannelStore.getAllGuilds()).find(x => x != null && x.VOCAL.length > 0).VOCAL[0].channel.id
            const streamKey = `call:${channelId}:1`
            let fn = async () => {
                while(true) {
                    const res = await api.post({url: `/quests/${quest.id}/heartbeat`, body: {stream_key: streamKey, terminal: false}})
                    const progress = res.body.progress.PLAY_ACTIVITY.value
                    sendStatus(`${Math.round((progress / secondsNeeded) * 100)}`, 'progress');
                    await new Promise(resolve => setTimeout(resolve, 20 * 1000))
                    if(progress >= secondsNeeded) {
                        await api.post({url: `/quests/${quest.id}/heartbeat`, body: {stream_key: streamKey, terminal: true}})
                        break
                    }
                }
                completedQuests++;
                sendStatus(`${completedQuests}`, 'completed');
                sendStatus(`${questName}`, 'success');
                doJob()
            }
            fn()
        }
    }
    doJob()
}
"""


def main():
    root = tk.Tk()
    app = QuestGUI(root)
    root.mainloop()


if __name__ == '__main__':
    main()
