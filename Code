# ─── Rounded-rect ───────────────────────────────────────────────────────────
def _rr(c, x1, y1, x2, y2, r=12, **kw):
    pts = [
        x1+r, y1,   x2-r, y1,
        x2,   y1,   x2,   y1+r,
        x2,   y2-r, x2,   y2,
        x2-r, y2,   x1+r, y2,
        x1,   y2,   x1,   y2-r,
        x1,   y1+r, x1,   y1,
        x1+r, y1,
    ]
    return c.create_polygon(pts, smooth=True, **kw)


# ─── Animated pulse dot ─────────────────────────────────────────────────────
class PulseDot:
    def __init__(self, parent, size=7):
        self.size = size
        self.cv = tk.Canvas(parent, width=size + 10, height=size + 10,
                            bg=TH['bg'], highlightthickness=0)
        self._c = TH['txt3']
        self._ph = 0.0
        self._on = False
        self._tick()

    def pack(self, **kw):
        self.cv.pack(**kw)

    def _tick(self):
        s = self.size
        c = self.cv
        c.delete('all')
        cx = cy = (s + 10) // 2
        d = s // 2
        if self._on:
            for ring in range(2):
                rr = d + 2 + int(3 * abs(math.sin(self._ph - ring * 0.6)))
                c.create_oval(cx - rr, cy - rr, cx + rr, cy + rr,
                              outline=self._c, width=1)
            self._ph += 0.2
            c.after(50, self._tick)
        c.create_oval(cx - d, cy - d, cx + d, cy + d, fill=self._c, outline='')

    def set_state(self, st):
        m = {'idle': (TH['txt3'], False), 'running': (TH['green'], True),
             'stopped': (TH['yellow'], False), 'error': (TH['red'], False)}
        self._c, self._on = m.get(st, (TH['txt3'], False))
        self._ph = 0.0


# ─── Progress bar ───────────────────────────────────────────────────────────
class ProgressBar:
    def __init__(self, parent, h=5):
        self.h = h
        self.cv = tk.Canvas(parent, height=h, bg=TH['glass'], highlightthickness=0, bd=0)
        self._v = 0
        self.cv.bind('<Configure>', self._draw)

    def pack(self, **kw):
        self.cv.pack(**kw)

    def set(self, v):
        self._v = max(0, min(100, v))
        self._draw()

    def _draw(self, *_):
        c = self.cv
        c.delete('all')
        w = c.winfo_width()
        if w < 4:
            return
        r = self.h // 2
        # trough
        _rr(c, 0, 0, w, self.h, r=r, fill=TH['dim'], outline='')
        fw = int(w * self._v / 100)
        if fw > self.h:
            # gradient fill
            steps = max(1, min(16, fw // 3))
            for i in range(steps):
                x1 = int(fw * i / steps)
                x2 = int(fw * (i + 1) / steps)
                t = i / max(steps - 1, 1)
                # lerp from dark purple to bright purple
                rr = int(100 + 34 * t)
                gg = int(80 + 45 * t)
                bb = int(210 + 45 * t)
                col = f'#{rr:02x}{gg:02x}{bb:02x}'
                rad = r if i == 0 else 0
                _rr(c, x1, 0, x2, self.h, r=rad, fill=col, outline='')
            # rounded end cap
            _rr(c, max(0, fw - self.h), 0, fw, self.h, r=r, fill=TH['pri_hov'], outline='')
            # tiny shimmer dot at the tip
            c.create_oval(fw - 3, 0, fw + 1, self.h, fill='#ffffff', outline='')


# ─── Stat tile ──────────────────────────────────────────────────────────────
class StatTile:
    def __init__(self, parent, label, val='—', vc=TH['txt']):
        self.cv = tk.Canvas(parent, bg=TH['bg'], highlightthickness=0)
        self.cv.bind('<Configure>', self._draw)
        self._lbl = label
        self._val = val
        self._vc = vc
        self._hov = False
        self.cv.bind('<Enter>', lambda e: self._set_hov(True))
        self.cv.bind('<Leave>', lambda e: self._set_hov(False))

    def _set_hov(self, v):
        self._hov = v
        self._draw()

    def _draw(self, *_):
        c = self.cv
        c.delete('all')
        w, h = c.winfo_width(), c.winfo_height()
        if w < 4:
            return
        bg = TH['glass_hov'] if self._hov else TH['glass']
        brd = TH['border'] if self._hov else TH['border_lite']
        # shadow
        _rr(c, 3, 4, w, h + 1, r=14, fill='#000000', outline='')
        # card body
        _rr(c, 1, 1, w - 1, h - 2, r=14, fill=bg, outline=brd, width=1)
        # accent bar
        bar_w = 24
        _rr(c, w // 2 - bar_w // 2, 4, w // 2 + bar_w // 2, 6, r=1, fill=self._vc, outline='')
        # label
        c.create_text(w // 2, h * 0.40, text=self._lbl,
                      fill=TH['txt3'], font=('Segoe UI Semibold', 7), anchor='center')
        # value — auto-scale font so full name fits
        display_val = self._val
        vlen = len(display_val)
        if vlen <= 8:
            vfsize = 14
        elif vlen <= 12:
            vfsize = 12
        elif vlen <= 18:
            vfsize = 10
        elif vlen <= 24:
            vfsize = 9
        else:
            vfsize = 8
            display_val = display_val[:22] + '…'
        c.create_text(w // 2, h * 0.72, text=display_val,
                      fill=self._vc, font=('Segoe UI', vfsize, 'bold'), anchor='center')

    def update(self, v):
        self._val = v
        self._draw()

    def grid(self, **kw):
        self.cv.grid(**kw)


# ─── Pill button ────────────────────────────────────────────────────────────
class PillButton:
    def __init__(self, parent, text, cmd, bg=TH['pri'], fg='#fff',
                 hover_bg=None, active_bg=None,
                 r=20, font=('Segoe UI Semibold', 9), state=tk.NORMAL):
        self._cmd = cmd
        self._bg = bg
        self._fg = fg
        self._hbg = hover_bg or bg
        self._abg = active_bg or bg
        self._r = r
        self._enabled = state == tk.NORMAL
        self._hov = False
        self._prs = False

        self.cv = tk.Canvas(parent,
                            bg=parent['bg'] if hasattr(parent, '__getitem__') else TH['bg'],
                            highlightthickness=0, height=36, cursor='hand2')
        self._txt = text
        self._font = font
        self.cv.bind('<Configure>', self._draw)
        self.cv.bind('<Button-1>', self._on_press)
        self.cv.bind('<ButtonRelease-1>', self._on_rel)
        self.cv.bind('<Enter>', self._on_enter)
        self.cv.bind('<Leave>', self._on_leave)

    def _draw(self, *_):
        c = self.cv
        c.delete('all')
        w, h = c.winfo_width(), c.winfo_height()
        if w < 4:
            return
        if not self._enabled:
            bg, fg = TH['dim'], TH['txt3']
            shadow = False
        elif self._prs:
            bg, fg = self._abg, self._fg
            shadow = False
        elif self._hov:
            bg, fg = self._hbg, self._fg
            shadow = True
        else:
            bg, fg = self._bg, self._fg
            shadow = True
        # soft shadow layers
        if shadow:
            for i in range(4, 0, -1):
                _rr(c, 2, 2 + i, w - 2, h - 1 + i, r=self._r, fill='#000000', outline='')
        # button body
        _rr(c, 2, 2, w - 2, h - 2, r=self._r, fill=bg, outline='')
        # inner highlight (subtle top edge)
        if self._enabled and not self._prs:
            _rr(c, 8, 3, w - 8, 6, r=2,
                fill=self._hbg if self._hov else bg, outline='')
        # text
        c.create_text(w // 2, h // 2 + 1, text=self._txt, fill=fg, font=self._font)

    def _on_press(self, e):
        if self._enabled:
            self._prs = True
            self._draw()

    def _on_rel(self, e):
        if self._enabled and self._prs:
            self._prs = False
            self._draw()
            self._cmd()

    def _on_enter(self, e):
        self._hov = True
        self._draw()

    def _on_leave(self, e):
        self._hov = False
        self._prs = False
        self._draw()

    def config_state(self, s):
        self._enabled = s == tk.NORMAL
        self.cv['cursor'] = 'hand2' if self._enabled else 'arrow'
        self._draw()

    def pack(self, **kw):
        self.cv.pack(**kw)

    def grid(self, **kw):
        self.cv.grid(**kw)


# ─── Custom scrollbar ───────────────────────────────────────────────────────
class ThinScrollbar(tk.Canvas):
    """A thin, rounded, auto-hiding scrollbar."""
    def __init__(self, parent, command=None, **kw):
        kw.setdefault('bg', TH['bg'])
        super().__init__(parent, width=6, highlightthickness=0, bd=0, **kw)
        self._cmd = command
        self._dragging = False
        self._top = 0.0
        self._bot = 1.0
        self.bind('<ButtonPress-1>', self._press)
        self.bind('<B1-Motion>', self._drag)
        self.bind('<ButtonRelease-1>', self._rel)
        self.bind('<Configure>', lambda e: self._render())

    def set(self, first, last):
        self._top = float(first)
        self._bot = float(last)
        self._render()

    def _render(self):
        self.delete('all')
        w = self.winfo_width()
        h = self.winfo_height()
        if h < 10 or self._bot - self._top >= 1.0:
            return
        y1 = max(2, int(h * self._top))
        y2 = min(h - 2, int(h * self._bot))
        if y2 - y1 < 14:
            y2 = y1 + 14
        _rr(self, 1, y1, w - 1, y2, r=3, fill=TH['border'], outline='')

    def _press(self, e):
        self._dragging = True
        self._move_to(e.y)

    def _drag(self, e):
        if self._dragging:
            self._move_to(e.y)

    def _rel(self, e):
        self._dragging = False

    def _move_to(self, y):
        h = self.winfo_height()
        if h < 1 or not self._cmd:
            return
        self._cmd('moveto', str(y / h))


