        for i in range(steps):
            x1 = int(w * i / steps)
            x2 = int(w * (i + 1) / steps) + 1
            t = i / max(steps - 1, 1)
            # purple to blue to purple arc
            r = int(100 + 24 * math.sin(t * math.pi))
            g = int(80 + 50 * math.sin(t * math.pi))
            b = int(200 + 55 * math.sin(t * math.pi))
            col = f'#{r:02x}{g:02x}{b:02x}'
            c.create_rectangle(x1, 0, x2, 3, fill=col, outline='')

